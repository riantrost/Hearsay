{
  "name": "hearsay",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vitest run && tsc --noEmit && tsc -p functions --noEmit && vite build && node scripts/verify-build.mjs",
    "preview": "vite preview",
    "api": "wrangler pages dev dist --port 8788",
    "db:local": "wrangler d1 migrations apply hearsay --local",
    "smoke": "node scripts/smoke-api.mjs",
    "deploy": "npm run build && wrangler pages deploy && node scripts/verify-deploy.mjs https://hearsay-preview.pages.dev"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@preact/preset-vite": "^2.10.6",
    "@preact/signals": "^2.9.4",
    "@testing-library/preact": "^3.2.4",
    "jsdom": "^29.1.1",
    "preact": "^10.29.7",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.109.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260714.1": true
  }
}
